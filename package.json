{
  "name": "undrecreaitwins",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source headless AI-clone (digital twin) backend",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r run build",
    "compose:standalone": "docker compose -f infra/docker-compose.standalone.yml up -d --build",
    "compose:orchestra": "docker compose -f infra/docker-compose.with-orchestra up -d --build",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r run test:unit",
    "test:integration": "pnpm -r run test:integration",
    "validate": "pnpm -r run validate",
    "lint": "pnpm -r run lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=.env node_modules/drizzle-kit/bin.cjs push"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "pg": "^8.21.0",
    "postgres": "^3.4.0",
    "tsx": "^4.22.3"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "discord.js": "^14.26.4",
    "drizzle-orm": "^0.45.2",
    "pino": "^9.6.0",
    "undici": "6.21.1",
    "ws": "^8.21.0"
  }
}
