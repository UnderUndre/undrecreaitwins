# ═══════════════════════════════════════════════════════════════════════════
# Twin Engine — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy to .env and fill in values.  No real secrets in this file.
# All vars derived from codebase — see packages/core/src/*.ts references.
# ═══════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_USER=undre
POSTGRES_PASSWORD=changeme
POSTGRES_DB=twinengine
POSTGRES_PORT=5432
# Full connection URL (standalone compose overrides host to "postgres";
# orchestra mode should point at the orchestra's Postgres):
DATABASE_URL=postgresql://undre:changeme@localhost:5432/twinengine

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── LLM Provider (OpenAI-compatible) ────────────────────────────────────
LLM_PROVIDER_URL=http://localhost:4000
LLM_API_KEY=
LLM_DEFAULT_MODEL=gpt-4o
VALIDATOR_JUDGE_MODEL=

# ── TEI Embedding Sidecars ──────────────────────────────────────────────
# Standalone compose uses internal tei-embed/tei-rerank services.
# Orchestra mode: point at the orchestra's TEI instances.
EMBEDDINGS_URL=http://localhost:8080
RERANK_URL=http://localhost:8081
TEI_EMBED_PORT=8080
TEI_RERANK_PORT=8081

# ── Letta (Agent Memory — optional) ────────────────────────────────────
LETTA_BASE_URL=http://localhost:8283
LETTA_TIMEOUT_MS=2000

# ── Langfuse (Observability — optional) ────────────────────────────────
# Langfuse is self-hosted in its own docker-compose.yml (separate from
# engine).  Leave keys empty to disable tracing (no-op singleton).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000

# ── API Server ──────────────────────────────────────────────────────────
PORT=8090
LOG_LEVEL=info
TWIN_AUTH_MODE=standalone
TWIN_MAX_UPLOAD_BYTES=524288000
TWIN_STREAM_TIMEOUT_MS=30000
TWIN_MAX_REPLY_LENGTH=4000

# ── Storage ─────────────────────────────────────────────────────────────
TWIN_STORAGE_BACKEND=local-fs
TWIN_UPLOAD_DIR=/tmp/twin-uploads

# ── Document / Training Worker ─────────────────────────────────────────
# (inherits DATABASE_URL, REDIS_URL, EMBEDDINGS_URL from above)

# ── Reengagement Worker (spec 009) ──────────────────────────────────────
TWIN_REENGAGE_CLAIM_TIMEOUT_MS=300000
TWIN_REENGAGE_LLM_TIMEOUT_MS=30000
TWIN_REENGAGE_WORKERS_BATCH=10
# TWIN_REENGAGE_WORKERS=4

# ── Channel: Telegram ──────────────────────────────────────────────────
TELEGRAM_CHANNEL_ID=
TELEGRAM_TENANT_ID=
TELEGRAM_PERSONA_SLUG=
TELEGRAM_BOT_TOKEN=

# ── Channel: WhatsApp via Evolution API ────────────────────────────────
WHATSAPP_CHANNEL_ID=
WHATSAPP_TENANT_ID=
WHATSAPP_PERSONA_SLUG=
WHATSAPP_INSTANCE_ID=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_PORT=8091
EVOLUTION_API_URL=http://localhost:8082
EVOLUTION_API_PORT=8082
EVOLUTION_API_KEY=changeme
EVOLUTION_DB=evolution

# ── Orchestra Mode (with-orchestra.yml only) ───────────────────────────
# External Docker network name for the orchestra stack.
# ORCHESTRA_NETWORK=orchestra

# ── Usage Emission (optional) ──────────────────────────────────────────
# USAGE_EMISSION_ENDPOINT=
