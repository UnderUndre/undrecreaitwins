{
  "name": "@undrecreaitwins/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./storage.js": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "validate": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
